<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:gravity="center"
    android:background="@drawable/widget_bg">

    <!-- Metrics row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Latency/Ping Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_ping"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:textStyle="bold" />
                
            <TextView
                android:id="@+id/widget_ping_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/ping_yellow"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Separator -->
        <FrameLayout
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/border_card" />

        <!-- Download Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingLeft="8dp"
            android:paddingRight="8dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_download"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:textStyle="bold" />
                
            <TextView
                android:id="@+id/widget_download_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/download_blue"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
                
            <ProgressBar
                android:id="@+id/widget_download_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_download" />
        </LinearLayout>

        <!-- Separator -->
        <FrameLayout
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/border_card" />

        <!-- Upload Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingLeft="8dp"
            android:paddingRight="8dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_upload"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:textStyle="bold" />
                
            <TextView
                android:id="@+id/widget_upload_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/upload_magenta"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
                
            <ProgressBar
                android:id="@+id/widget_upload_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_upload" />
        </LinearLayout>

    </LinearLayout>

    <!-- Status row -->
    <TextView
        android:id="@+id/widget_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_never_tested"
        android:textColor="@color/text_secondary"
        android:textSize="9sp"
        android:gravity="center"
        android:layout_marginTop="4dp" />

</LinearLayout>
