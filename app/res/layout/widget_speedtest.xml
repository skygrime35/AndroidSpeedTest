<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="6dp"
    android:gravity="center"
    android:background="@drawable/widget_bg">

    <!-- Metrics Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Latency (Ping) Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PING"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/widget_ping_loading"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginLeft="4dp"
                    android:visibility="gone" />
            </LinearLayout>
                
            <TextView
                android:id="@+id/widget_ping_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/ping_yellow"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/border_card"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp" />

        <!-- Download Speed Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:gravity="center">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↓ DOWN"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/widget_download_loading"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginLeft="4dp"
                    android:visibility="gone" />
            </LinearLayout>
                
            <TextView
                android:id="@+id/widget_download_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/download_blue"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="1dp" />
                
            <ProgressBar
                android:id="@+id/widget_download_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="3dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_download" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/border_card"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp" />

        <!-- Upload Speed Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:gravity="center">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ UP"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/widget_upload_loading"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginLeft="4dp"
                    android:visibility="gone" />
            </LinearLayout>
                
            <TextView
                android:id="@+id/widget_upload_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/upload_magenta"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="1dp" />
                
            <ProgressBar
                android:id="@+id/widget_upload_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="3dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_upload" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
