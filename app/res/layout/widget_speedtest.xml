<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg">

    <!-- Left Column: Brand & Status -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="3"
        android:orientation="vertical"
        android:gravity="left|center_vertical">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPEED"
                android:textColor="@color/download_blue"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TEST"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginLeft="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_never_tested"
            android:textColor="@color/text_secondary"
            android:textSize="8sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="24dp"
        android:background="@color/border_card"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp" />

    <!-- Latency (Ping) Column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="center">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PING"
            android:textColor="@color/text_secondary"
            android:textSize="8sp"
            android:textStyle="bold" />
            
        <TextView
            android:id="@+id/widget_ping_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/ping_yellow"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="1dp" />
    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="24dp"
        android:background="@color/border_card"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp" />

    <!-- Download Speed Column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.5"
        android:orientation="vertical"
        android:gravity="center">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↓ DOWN"
            android:textColor="@color/text_secondary"
            android:textSize="8sp"
            android:textStyle="bold" />
            
        <TextView
            android:id="@+id/widget_download_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/download_blue"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="1dp" />
            
        <ProgressBar
            android:id="@+id/widget_download_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="3dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_download" />
    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="24dp"
        android:background="@color/border_card"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp" />

    <!-- Upload Speed Column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.5"
        android:orientation="vertical"
        android:gravity="center">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↑ UP"
            android:textColor="@color/text_secondary"
            android:textSize="8sp"
            android:textStyle="bold" />
            
        <TextView
            android:id="@+id/widget_upload_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/upload_magenta"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="1dp" />
            
        <ProgressBar
            android:id="@+id/widget_upload_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="3dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_upload" />
    </LinearLayout>

</LinearLayout>
